# Local dev (Homebrew Postgres): postgresql://<macos-username>@localhost:5432/craigslist_watch?schema=public
# Docker Compose: postgresql://craigslist_watch:craigslist_watch@db:5432/craigslist_watch?schema=public
DATABASE_URL=""

# Email — pick ONE provider.
# Resend: https://resend.com/api-keys
RESEND_API_KEY=""
# SMTP fallback if RESEND_API_KEY is unset, e.g. "smtp://user:pass@host:port"
SMTP_URL=""
EMAIL_FROM="alerts@example.com"
# Where alert emails get sent.
NOTIFY_TO_EMAIL=""

# App
CRAWL_INTERVAL_MINUTES=20
DIGEST_DAILY_HOUR=8
TZ=America/Los_Angeles

# Optional — real transit routing for commute estimates via Google's
# Directions API (restrict the key to "Directions API" only). Falls back to
# a free straight-line heuristic if unset.
GOOGLE_MAPS_API_KEY=""
