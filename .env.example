# Local dev (Homebrew Postgres): postgresql://<macos-username>@localhost:5432/craigslist_watch?schema=public
# Docker Compose: postgresql://craigslist_watch:craigslist_watch@db:5432/craigslist_watch?schema=public
DATABASE_URL=""

# Email — pick ONE provider.
# Resend: https://resend.com/api-keys
RESEND_API_KEY=""
# SMTP fallback if RESEND_API_KEY is unset, e.g. "smtp://user:pass@host:port"
SMTP_URL=""
EMAIL_FROM="alerts@example.com"
# Recipients are per-saved-search now (each one's Profile.email, set up when
# alerts are turned on for that search) — there's no single global recipient.

# App
CRAWL_INTERVAL_MINUTES=20
DIGEST_DAILY_HOUR=8
# Once-a-week, no-price-filter crawl of every supported city (independent of
# any saved search) — keeps browsing/the Rent Map populated beyond just what
# active watches happen to cover. Off-peak by default since it's a much
# bigger crawl than the regular cycle (see runFullCityCrawl). Day 0 = Sunday.
FULL_CRAWL_HOUR=3
FULL_CRAWL_DAY_OF_WEEK=0
# Also set these on your hosting provider (e.g. Railway's dashboard), not
# just here — .env isn't deployed with the app, and DIGEST_DAILY_HOUR/
# FULL_CRAWL_HOUR/FULL_CRAWL_DAY_OF_WEEK are interpreted in whatever this
# resolves to at runtime.
TZ=America/Los_Angeles

# Optional — real transit routing for commute estimates via Google's
# Directions API (restrict the key to "Directions API" only). Falls back to
# a free straight-line heuristic if unset.
GOOGLE_MAPS_API_KEY=""

# Optional — gates the whole site behind one shared password (a /login page).
# Leave blank to disable.
APP_PASSWORD=""

# Public origin of this app — used to build the "pause this search" link in
# notification emails. Leave unset to omit that link.
APP_URL=""
